# .gitignore
#
# Tells git which files/folders to NEVER track or upload to GitHub.
# This matters for three reasons:
#   1. Security — secrets (API keys) must never be committed.
#   2. Size — virtual environments and cache files are huge and regenerable.
#   3. Cleanliness — machine-specific files shouldn't clutter shared history.

# Python virtual environment (created locally per machine; never shared)
venv/
env/
.venv/

# Python bytecode cache (auto-generated, regenerated every run)
__pycache__/
*.pyc

# Log files (machine-specific runtime output, not source code)
logs/

# Persistent memory database (Phase 6) — this is YOUR personal
# conversation history, not source code, and shouldn't be shared or
# committed to a public/shared repository.
data/

# Downloaded offline speech-recognition model (~40MB+) — you download
# this yourself (see README), it's not source code, and it's too large
# to sensibly commit to git.
data/vosk-model/

# Secrets — created in Phase 3 to hold API keys. Never commit this file.
.env

# Editor/OS clutter
.vscode/
.idea/
.DS_Store
